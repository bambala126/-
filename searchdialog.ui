        <item>
         <widget class="QCheckBox" name="checkBoxContent">
          <property name="text"><string>Содержимом</string></property>
          <property name="checked"><bool>true</bool></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
         </spacer>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
   <!-- Results -->
   <item>
