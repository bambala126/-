          <property name="default"><bool>true</bool></property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel" name="labelIn">
          <property name="text"><string>Искать в:</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="checkBoxName">
          <property name="text"><string>Названиях узлов</string></property>
          <property name="checked"><bool>true</bool></property>
